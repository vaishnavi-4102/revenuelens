# Copy to airflow/.env (never commit the real file) before `docker compose up`.

# Run the container as your own host user, not the image's baked-in uid --
# the repo is bind-mounted read-write, so this is what lets the container
# write into data_generator/output/ and dbt/target/ without a permission
# error. Get these with `id -u` / `id -g` on the host.
AIRFLOW_UID=1000
AIRFLOW_GID=0

# Airflow webserver login (http://localhost:8080)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Snowflake connection, as Airflow's JSON connection form -- not the URI
# form (snowflake://user:pass@account/?warehouse=...&database=...). The URI
# form is genuinely broken here: confirmed live that with database/schema
# passed as query-string params (rather than path segments) and a password
# containing special characters, the Snowflake provider intermittently
# mis-parses the account identifier -- "Account must be specified" fails
# 2 out of 5 parallel tasks running the exact same connection, not a
# privilege issue, a parser race. JSON has no such ambiguity: every field
# is explicit. Password needs no URL-encoding here either.
# role/warehouse/database below are what 10_ingestion.py's SnowflakeHook
# uses by default -- point database at whichever env you're demoing against.
AIRFLOW_CONN_SNOWFLAKE_DEFAULT={"conn_type": "snowflake", "login": "USER", "password": "PASSWORD", "extra": {"account": "ACCOUNT_IDENTIFIER", "warehouse": "RL_LOADING_WH", "database": "RL_DEV", "schema": "RAW", "role": "RL_LOADER"}}

# dbt's BashOperator tasks (20_dbt_staging, 30_dbt_marts_and_tests) are a
# separate bash subprocess -- they don't inherit anything from the
# AIRFLOW_CONN_SNOWFLAKE_DEFAULT connection above, which only the Python/
# SnowflakeHook ingestion tasks read. profiles.yml's env_var() calls need
# these directly, same as running dbt locally would.
SNOWFLAKE_ACCOUNT=ACCOUNT_IDENTIFIER
SNOWFLAKE_USER=USER
SNOWFLAKE_PASSWORD=PASSWORD
