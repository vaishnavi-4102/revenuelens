# Copy to ~/.dbt/profiles.yml (or set DBT_PROFILES_DIR) and fill in via
# environment variables -- never commit real credentials. Airflow and CI use
# the same env-var names via their own secret stores (Airflow connection /
# GitHub Actions secrets), so this file is the single source of truth for
# which variables are required.
#
# database is the only thing that changes per environment (RL_DEV/RL_QA/
# RL_PROD) -- schema is deliberately a placeholder because
# macros/generate_schema_name.sql ignores target.schema for every model in
# this project (every model sets an explicit +schema for its layer).
revenuelens:
  target: dev
  outputs:

    dev:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      # dev is the one target a human runs interactively, so it's also the
      # only one that supports SSO: set SNOWFLAKE_AUTHENTICATOR=externalbrowser
      # and skip SNOWFLAKE_PASSWORD entirely -- dbt will pop open a browser
      # window for the SSO login instead. qa/prod/ci are driven by Airflow
      # and CI, which can't click through a browser prompt, so those stay on
      # password/key-pair auth.
      authenticator: "{{ env_var('SNOWFLAKE_AUTHENTICATOR', 'snowflake') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD', '') }}"
      private_key_path: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PATH', '') }}"
      private_key_passphrase: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PASSPHRASE', '') }}"
      role: RL_TRANSFORMER
      database: RL_DEV
      warehouse: RL_TRANSFORMING_WH
      schema: DBT_DEFAULT
      threads: 4

    qa:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD', '') }}"
      private_key_path: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PATH', '') }}"
      private_key_passphrase: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PASSPHRASE', '') }}"
      role: RL_TRANSFORMER
      database: RL_QA
      warehouse: RL_TRANSFORMING_WH
      schema: DBT_DEFAULT
      threads: 4

    prod:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD', '') }}"
      private_key_path: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PATH', '') }}"
      private_key_passphrase: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PASSPHRASE', '') }}"
      role: RL_TRANSFORMER
      database: RL_PROD
      warehouse: RL_TRANSFORMING_WH
      schema: DBT_DEFAULT
      threads: 8

    # Used only by .github/workflows/dbt_ci.yml. database is a per-PR
    # zero-copy clone of RL_PROD (RL_CI_PR_<number>, created and dropped by
    # the workflow itself) -- SNOWFLAKE_CI_DATABASE is set by CI, not a
    # human. RL_CI_WH keeps CI spend attributable and separate from any
    # interactive warehouse (the D5 cost story).
    ci:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD', '') }}"
      private_key_path: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PATH', '') }}"
      private_key_passphrase: "{{ env_var('SNOWFLAKE_PRIVATE_KEY_PASSPHRASE', '') }}"
      role: RL_TRANSFORMER
      database: "{{ env_var('SNOWFLAKE_CI_DATABASE', 'RL_CI') }}"
      warehouse: RL_CI_WH
      schema: DBT_DEFAULT
      threads: 4
